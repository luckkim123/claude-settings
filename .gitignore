# Secrets — never commit real API keys
secrets/secrets.env
secrets/*.env
!secrets/secrets.example.env

# Local overrides (machine-specific) — but keep templated examples committed
*.local.json
*.local.*
!templates/*.example.*

# Generated artifacts (install.sh outputs)
**/mcp.json
!claude/mcp.template.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Backups
*.bak
.backup-*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python virtual envs / caches
**/.venv/
**/__pycache__/
*.pyc
