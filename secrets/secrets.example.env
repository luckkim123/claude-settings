# Real API keys go in secrets/secrets.env (gitignored).
# install.sh substitutes ${VAR} placeholders in claude/mcp.template.json with values from this file.
#
# Currently no secrets are required — leave secrets.env absent unless you add an MCP server
# that needs a key.
#
# Example:
#   SMITHERY_API_KEY=...
#   OPENAI_API_KEY=...
